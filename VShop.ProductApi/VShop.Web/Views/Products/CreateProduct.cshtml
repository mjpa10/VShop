@model VShop.Web.Models.ProductViewModel
<link rel="stylesheet" href="/css/management.css" asp-append-version="true" />

<form asp-action="CreateProduct" class="form-wrap">
    <h1 class="form-title">Novo produto</h1>

    <div asp-validation-summary="All" class="form-error"></div>

    <div class="form-field">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-input" placeholder="" />
        <span asp-validation-for="Name" class="form-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-textarea" placeholder="Descreva o produto..."></textarea>
        <span asp-validation-for="Description" class="form-error"></span>
    </div>

    <div class="form-field">
        <label asp-for="ImageURL" class="form-label"></label>
        <input asp-for="ImageURL" class="form-input" placeholder="" />
        <span asp-validation-for="ImageURL" class="form-error"></span>
    </div>

    <div class="form-row">
        <div class="form-field">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" asp-format="{0:N2}" class="form-input" placeholder="0,00" />
            <span asp-validation-for="Price" class="form-error"></span>
        </div>
        <div class="form-field">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-input" placeholder="0" />
            <span asp-validation-for="Stock" class="form-error"></span>
        </div>
    </div>

    <div class="form-field">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select" asp-items="@ViewBag.CategoryId"></select>
    </div>

    <div class="form-actions">
        <a asp-action="Index" class="btn-back-form">← Voltar</a>
        <button type="submit" class="btn-submit">Criar produto</button>
    </div>
</form>