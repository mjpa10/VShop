@model IEnumerable<VShop.Web.Models.ProductViewModel>
<link rel="stylesheet" href="/css/management.css" asp-append-version="true" />

<div class="mgmt-wrap">
    <div class="mgmt-header">
        <span class="mgmt-title">Gestão de produtos</span>
        <a asp-action="CreateProduct" class="btn-new">
            <i class="fas fa-plus" style="font-size:13px"></i> Novo produto
        </a>
    </div>

    <table class="mgmt-table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(m => m.Name)</th>
                <th>@Html.DisplayNameFor(m => m.CategoryName)</th>
                <th>@Html.DisplayNameFor(m => m.Description)</th>
                <th>@Html.DisplayNameFor(m => m.Price)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="td-name">@item.Name</td>
                    <td><span class="td-badge">@item.CategoryName</span></td>
                    <td class="td-desc">@item.Description</td>
                    <td class="td-price">@item.Price.ToString("C")</td>
                    <td>
                        <div class="td-actions">
                            <a asp-action="UpdateProduct" asp-route-id="@item.Id" class="btn-edit" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="DeleteProduct" asp-route-id="@item.Id" class="btn-del" title="Deletar">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>