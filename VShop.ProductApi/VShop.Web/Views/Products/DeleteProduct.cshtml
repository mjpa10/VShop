@model VShop.Web.Models.ProductViewModel
<link rel="stylesheet" href="/css/management.css" asp-append-version="true" />

<div class="delete-wrap">
    <div class="delete-header">
        <h1 class="delete-title">Excluir produto</h1>
        <p class="delete-sub">Revise os dados antes de confirmar a exclusão.</p>
    </div>

    <div class="delete-card">
        <img class="delete-img" src="/images/@Model.CategoryName/@Model.ImageURL" alt="@Model.Name" />
        <div class="delete-info">
            <p class="delete-name">@Model.Name</p>
            <div class="delete-meta">
                <div class="delete-meta-row">
                    <span class="delete-meta-label">Categoria</span>
                    <span class="delete-meta-value">@Model.CategoryName</span>
                </div>
                <div class="delete-meta-row">
                    <span class="delete-meta-label">Preço</span>
                    <span class="delete-meta-value">@Model.Price.ToString("C")</span>
                </div>
                <div class="delete-meta-row">
                    <span class="delete-meta-label">Estoque</span>
                    <span class="delete-meta-value">@Model.Stock itens</span>
                </div>
                <div class="delete-meta-row">
                    <span class="delete-meta-label">Descrição</span>
                    <span class="delete-meta-value">@Model.Description</span>
                </div>
            </div>
        </div>
    </div>

    <div class="delete-warning">
        <i class="fas fa-exclamation-triangle" style="font-size:16px;flex-shrink:0"></i>
        Esta ação é irreversível. O produto será excluído permanentemente.
    </div>

    <form asp-action="DeleteProduct" class="delete-actions">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn-cancel">← Cancelar</a>
        <button type="submit" class="btn-delete">Confirmar exclusão</button>
    </form>
</div>