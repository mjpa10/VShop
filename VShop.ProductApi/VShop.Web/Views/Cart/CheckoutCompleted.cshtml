<link rel="stylesheet" href="/css/cart.css" asp-append-version="true" />

<div class="success-wrap">
    <div class="success-icon">
        <i class="fas fa-check"></i>
    </div>
    <h1 class="success-title">Pedido confirmado!</h1>
    <p class="success-sub">Obrigado pelo seu pagamento. Seu pedido foi recebido com sucesso.</p>
    <div class="order-badge">
        <span class="order-badge-label">Número do pedido</span>
        <span class="order-badge-number">@ViewBag.OrderNumber</span>
    </div>
    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-back">
        ← Voltar às compras
    </a>
</div>