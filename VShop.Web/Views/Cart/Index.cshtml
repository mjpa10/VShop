@model CartViewModel
<link rel="stylesheet" href="/css/cart.css" asp-append-version="true" />

@if (Model.CartHeader is not null && Model.CartItems.Count() > 0)
{
    <form method="post">
        <input asp-for="CartHeader.UserId" hidden />
        <input asp-for="CartHeader.Id" hidden />
        <input asp-for="CartItems" hidden />
        <input asp-for="CartHeader.Discount" hidden />

        <div class="cart-wrap">
            <div class="cart-header">
                <span class="cart-title">Carrinho</span>
                <a asp-action="Index" asp-controller="Home" class="btn-shop">← Continuar comprando</a>
            </div>

            <div class="cart-cols">
                <span class="cart-col-label" style="padding-left:78px">Produto</span>
                <span class="cart-col-label">Preço</span>
                <span class="cart-col-label">Quantidade</span>
                <span></span>
            </div>

            @foreach (var item in Model.CartItems)
            {
                <div class="cart-item">
                    <div class="cart-item-info">
                        <img class="cart-item-img" src="/images/@item.Product.CategoryName/@item.Product.ImageURL" alt="@item.Product.Name" />
                        <div>
                            <p class="cart-item-name">@item.Product.Name</p>
                            <p class="cart-item-desc">@Html.Raw(item.Product.Description)</p>
                        </div>
                    </div>
                    <span class="cart-item-price">@item.Product.Price.ToString("C")</span>
                    <span class="cart-item-qty">@item.Quantity</span>
                    <a asp-action="RemoveItem" asp-route-id="@item.Id" class="btn-remove" aria-label="Remover">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            }

            <div class="cart-footer">
                <div>
                    <p class="coupon-label">Cupom de desconto</p>
                    <div class="coupon-row">
                        @if (string.IsNullOrEmpty(Model.CartHeader.CouponCode))
                        {
                            <input asp-for="CartHeader.CouponCode" class="coupon-input" placeholder="Digite seu cupom" />
                            <button type="submit" asp-action="ApplyCoupon" class="btn-coupon">Aplicar</button>
                        }
                        else
                        {

                            <input asp-for="CartHeader.CouponCode" hidden />
                            <input asp-for="CartHeader.CouponCode" class="coupon-input" disabled />
                            <button type="submit" asp-action="DeleteCoupon" class="btn-coupon">Remover</button>
                        }
                    </div>
                </div>
                <div class="total-wrap">
                    <span class="total-label">Total</span>
                    <span class="total-amount">@Model.CartHeader.TotalAmount.ToString("C")</span>
                    <a asp-action="Checkout" class="btn-checkout">Finalizar compra</a>
                </div>
            </div>
        </div>
    </form>
}
else
{
    <div class="cart-wrap">
        <p style="color:var(--text-muted)">Carrinho vazio. <a asp-action="Index" asp-controller="Home">Voltar às compras</a></p>
    </div>
}