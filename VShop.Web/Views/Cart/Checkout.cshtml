@model CartViewModel
<link rel="stylesheet" href="/css/cart.css" asp-append-version="true" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

@if (Model is not null && Model.CartItems.Count() > 0)
{
    <form method="post">
        <input asp-for="CartHeader.UserId" hidden />
        <input asp-for="CartHeader.Id" hidden />
        <input asp-for="CartHeader.CouponCode" hidden />
        <input asp-for="CartHeader.Discount" hidden />
        <input asp-for="CartHeader.TotalAmount" hidden />
        <input asp-for="CartItems" hidden />

        <div class="co-wrap">
            <div>
                <p class="co-title">Dados de entrega</p>

                <div class="co-section">
                    <p class="co-section-label">
                        <i class="fas fa-user" style="font-size:13px"></i> Nome
                    </p>
                    <div class="co-row">
                        <div class="co-field">
                            <label class="co-label">Primeiro nome</label>
                            <input asp-for="CartHeader.FirstName" class="co-input" placeholder="" required />
                        </div>
                        <div class="co-field">
                            <label class="co-label">Sobrenome</label>
                            <input asp-for="CartHeader.LastName" class="co-input" placeholder="" required />
                        </div>
                    </div>
                </div>

                <div class="co-section">
                    <p class="co-section-label">
                        <i class="fas fa-envelope" style="font-size:13px"></i> Contato
                    </p>
                    <div class="co-field">
                        <label class="co-label">E-mail</label>
                        <input asp-for="CartHeader.Email" class="co-input" placeholder="exemplo@email.com" required />
                    </div>
                    <div class="co-field">
                        <label class="co-label">Telefone</label>
                        <input asp-for="CartHeader.Telephone" class="co-input" placeholder="(81) 99999-9999" required />
                    </div>
                </div>

                <div class="co-section">
                    <p class="co-section-label">
                        <i class="fas fa-credit-card" style="font-size:13px"></i> Pagamento
                    </p>
                    <div class="co-row">
                        <div class="co-field">
                            <label class="co-label">Número do cartão</label>
                            <input asp-for="CartHeader.CardNumber" class="co-input" placeholder="" required />
                        </div>
                        <div class="co-field">
                            <label class="co-label">Nome no cartão</label>
                            <input asp-for="CartHeader.NameOnCard" class="co-input" placeholder="" required />
                        </div>
                    </div>
                    <div class="co-row">
                        <div class="co-field">
                            <label class="co-label">CVV</label>
                            <input asp-for="CartHeader.CVV" class="co-input" placeholder="" required />
                        </div>
                        <div class="co-field">
                            <label class="co-label">Validade</label>
                            <input asp-for="CartHeader.ExpireMonthYear" class="co-input" placeholder="MM/AA" maxlength="5" required />
                        </div>
                    </div>
                </div>
            </div>

            <div class="basket-wrap">
                <p class="basket-title">Resumo do pedido</p>

                @foreach (var item in Model.CartItems)
                {
                    <div class="basket-item">
                        <span class="basket-item-name">@item.Product.Name</span>
                        <span class="basket-item-price">@item.Product.Price.ToString("C")</span>
                        <span class="basket-item-qty">×@item.Quantity</span>
                    </div>
                }

                @if (Model.CartHeader.Discount > 0)
                {
                    <div class="basket-discount">
                        <span class="basket-discount-label">Desconto (@Model.CartHeader.CouponCode)</span>
                        <span class="basket-discount-value">− @string.Format("{0:P}", Model.CartHeader.Discount / 100)</span>
                    </div>
                }

                <div class="basket-total-row">
                    <span class="basket-total-label">Total</span>
                    <span class="basket-total-amount">@Model.CartHeader.TotalAmount.ToString("C")</span>
                </div>

                <button type="submit" class="btn-checkout">Confirmar pedido</button>
            </div>
        </div>
    </form>
}