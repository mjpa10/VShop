@model IEnumerable<VShop.Web.Models.ProductViewModel>
<link rel="stylesheet" href="/css/product.css" asp-append-version="true" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700&display=swap" rel="stylesheet" />

<form>
    <div class="container py-4">
        <div class="catalog-header">
            <span class="catalog-title">Catálogo</span>
            <span class="catalog-count">@Model.Count() produtos</span>
        </div>
        <div class="row row-cols-2 row-cols-md-4 g-3">
            @foreach (var product in Model)
            {
                <div class="col">
                    <a href="/Home/ProductDetails/@product.Id" class="product-link">
                        <div class="card h-100">
                            <div class="product-img-wrap">
                                <img src="/images/@product.CategoryName/@product.ImageURL" alt="@product.Name" />
                                <span class="product-badge">@product.CategoryName</span>
                            </div>
                            <div class="card-body">
                                <p class="product-category">@product.CategoryName</p>
                                <h6 class="product-name">@product.Name</h6>
                                <div class="product-footer">
                                    <span class="product-price">@product.Price.ToString("C")</span>
                                    <div class="add-btn">+</div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</form>