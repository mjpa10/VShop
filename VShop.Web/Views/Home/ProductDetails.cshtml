@model VShop.Web.Models.ProductViewModel
<link rel="stylesheet" href="/css/product.css" asp-append-version="true" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />


<form method="post" class="pd-wrap">
    <input asp-for="Id" hidden />

    <div class="pd-img-wrap">
        <img src="/images/@Model.CategoryName/@Model.ImageURL" alt="@Model.Name" />
    </div>

    <div class="pd-info">
        <span class="pd-breadcrumb">@Model.CategoryName</span>
        <h1 class="pd-name">@Model.Name</h1>
        <p class="pd-desc">@Model.Description</p>
        <hr class="pd-divider" />
        <div class="pd-price-row">
            <span class="pd-price">@Model.Price.ToString("C")</span>
            <span class="pd-stock">@Model.Stock itens em estoque</span>
        </div>
        <div class="pd-qty-row">
            <span class="pd-qty-label">Quantidade</span>
            <div class="pd-qty-ctrl">
                <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
                <span class="qty-val" id="qty-display">1</span>
                <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
                <input asp-for="Quantity" id="qty-input" hidden />
            </div>
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>
        <div class="pd-actions">
            <a asp-action="Index" class="btn-back">← Voltar</a>
            <button type="submit" class="btn-cart">
                <i class="ti ti-shopping-cart"></i>
                Adicionar ao carrinho
            </button>
        </div>
    </div>
</form>

<script>
    function changeQty(d) {
        const display = document.getElementById('qty-display');
        const input = document.getElementById('qty-input');
        const v = Math.max(1, parseInt(display.textContent) + d);
        display.textContent = v;
        input.value = v;
    }
</script>